{
  "manifest_version": 3,
  "name": "Purrfect Break – Cat Rest Reminder",
  "version": "2.0.0",
  "description": "A sleepy cat appears every 15 minutes to remind you to rest and sip water 🐱",
  "permissions": ["alarms", "storage", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/cat16.png",
      "32": "icons/cat32.png",
      "48": "icons/cat48.png",
      "128": "icons/cat128.png"
    }
  },
  "icons": {
    "16": "icons/cat16.png",
    "32": "icons/cat32.png",
    "48": "icons/cat48.png",
    "128": "icons/cat128.png"
  }
}
